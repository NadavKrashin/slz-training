# Enable Firebase emulators for local development
NEXT_PUBLIC_USE_EMULATORS=true

# Dummy Firebase config for emulator mode (emulators don't validate these)
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-slz-training
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-slz-training.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo
