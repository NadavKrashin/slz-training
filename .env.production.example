# Production environment — Firebase project: slz-training
# Copy to .env.production and fill in values from Firebase Console.
# .env.production is gitignored; this template is checked in.

NEXT_PUBLIC_USE_EMULATORS=false

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=slz-training.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=slz-training
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=slz-training.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Firebase Cloud Messaging VAPID key for production
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BNtV...
