# Staging environment — Firebase project: slz-training-staging
# Copy to .env.staging and fill in values from Firebase Console.
# .env.staging is gitignored; this template is checked in.

NEXT_PUBLIC_USE_EMULATORS=false

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=slz-training-staging.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=slz-training-staging
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=slz-training-staging.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Firebase Cloud Messaging VAPID key for staging
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BNtV...
