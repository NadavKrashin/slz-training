rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function sharesWithAdmin(uid) {
      let userDoc = get(/databases/$(database)/documents/users/$(uid));
      return userDoc != null && userDoc.data.shareCompletionWithAdmin == true;
    }

    // Users
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() ||
        (isAuth() && resource.data.shareCompletionWithAdmin == true);
      allow create: if isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.role in ['user', 'guest'];
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'email', 'shareCompletionWithAdmin', 'fcmToken', 'role', 'photoURL', 'updatedAt']) &&
        // Prevent users from self-promoting to admin via direct Firestore writes.
        // Admins are exempt since their role is already 'admin' and must stay that way.
        (isAdmin() || request.resource.data.role in ['user', 'guest']);
      allow delete: if false;
    }

    // Workouts by date
    match /workoutsByDate/{dateKey} {
      allow read: if isAuth();
      allow create, update: if isAdmin() &&
        request.resource.data.totalDurationSeconds == 600;
      allow delete: if isAdmin();
    }

    // Workout completions
    // Document IDs follow the pattern {uid}_{dateKey}.
    // Keep both checks:
    // - docId match allows single-doc reads before the doc exists.
    // - uid field allows collection queries (history/streak) to pass rules.
    match /workoutCompletions/{docId} {
      allow read: if isAuth() && (
        resource.data.uid == request.auth.uid ||
        docId.matches(request.auth.uid + '_.+') ||
        sharesWithAdmin(resource.data.uid)
      );
      allow create: if isAuth() &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['completedAt', 'updatedAt']);
      allow delete: if false;
    }

    // App settings
    match /appSettings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Motivational messages
    match /motivationalMessages/{msgId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Notification logs (written by Cloud Functions via admin SDK)
    match /notificationLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
